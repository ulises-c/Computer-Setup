# Copy this file to .env and set the values. The .env is gitignored.

# restic repository on the dedicated 1TB backup drive.
RESTIC_REPOSITORY=/mnt/wd1tb/restic
# Encryption password. STORE THIS IN BITWARDEN — without it the backup is
# permanently unrecoverable. Escape a literal $ as $$ (Docker/Compose-style).
RESTIC_PASSWORD=
# Mountpoint the script asserts before writing (must hold a .backup-target-ok file).
BACKUP_MOUNT=/mnt/wd1tb

# Optional second copy for redundancy (3-2-1-ish). Leave SECOND_RESTIC_REPOSITORY
# empty to disable. Uses the same RESTIC_PASSWORD.
SECOND_RESTIC_REPOSITORY=/mnt/wd14tb/restic-copy
SECOND_BACKUP_MOUNT=/mnt/wd14tb

# Retention (snapshots kept after each prune).
RETENTION_KEEP_DAILY=7
RETENTION_KEEP_WEEKLY=4
RETENTION_KEEP_MONTHLY=6

# Run `restic check` each night (structure verification). Set false to skip.
RUN_CHECK=true

# ntfy alerts — base URL of your ntfy server (tailnet domain works from the host)
# plus the topic. NTFY_TOKEN only needed if the topic requires auth.
NTFY_URL=https://ntfy.<tailnet>.ts.net
NTFY_TOPIC=server-backup
NTFY_TOKEN=

# Uptime Kuma heartbeat — create a "Push" monitor in Kuma and paste its push URL
# here, base only (up to the token, no query string). The script appends
# status/msg/ping each run; a missed run trips Kuma's heartbeat alert. Empty = off.
KUMA_PUSH_URL=https://uptime-kuma.<tailnet>.ts.net/api/push/<token>

# Extra absolute paths to back up (space-separated), e.g. if a service's data
# lives on an external drive. Forgejo's FORGEJO_DATA_PATH is auto-detected.
BACKUP_EXTRA_PATHS=
