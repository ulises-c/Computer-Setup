[Unit]
Description=Server backup (restic → external drive)
# Don't run unless the backup drive is mounted.
RequiresMountsFor=/mnt/wd1tb
After=network-online.target docker.service
OnFailure=backup-failure.service

[Service]
Type=oneshot
ExecStart=/home/ulises/github/Computer-Setup/linux-server/backup/backup.sh
# Runs as root to read all container-owned data dirs and drive docker.
Nice=10
IOSchedulingClass=idle
