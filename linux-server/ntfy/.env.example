# Copy this file to .env and update the values. See ../HTTPS.md for the full setup.

# Public HTTPS URL (no trailing slash) — must match the Tailscale sidecar domain,
# or notification/web links and the web app break. ntfy reads NTFY_BASE_URL.
NTFY_BASE_URL=https://ntfy.<tailnet>.ts.net

# Tailscale auth for the sidecar — same OAuth client secret as the other sidecars
# (needs the Auth Keys scope + tag:container in the ACL).
TS_AUTHKEY=
