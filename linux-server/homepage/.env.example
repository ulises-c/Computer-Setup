# Copy this file to .env and update the values.
# HOMEPAGE_VAR_* variables are available in config YAMLs as {{HOMEPAGE_VAR_*}}

# Used in services.yaml for service hrefs — use hostname (avahi mDNS) to avoid hardcoding an IP
# Access the dashboard at http://<hostname>.local:3000
HOMEPAGE_VAR_SERVER_IP=ollie-server.local

# Tailscale widget — optional, shows device IP and connection status on the dashboard
# Without these, the Tailscale card still links to the admin console but the widget shows an error
#
# HOMEPAGE_VAR_TAILSCALE_DEVICE_ID — get with: tailscale status --json | jq -r '.Self.ID'
# HOMEPAGE_VAR_TAILSCALE_API_KEY   — generate at: https://login.tailscale.com/admin/settings/keys
#                                    (read-only key with Devices scope is sufficient)
#HOMEPAGE_VAR_TAILSCALE_DEVICE_ID=
#HOMEPAGE_VAR_TAILSCALE_API_KEY=
