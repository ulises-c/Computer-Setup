# Required — generate with: echo "base64:$(openssl rand -base64 32)"
# (setup.sh auto-generates this when it first creates .env from this example)
APP_KEY=

# Public HTTPS URL — must match the Tailscale sidecar domain (see ../HTTPS.md) so
# the Laravel app builds correct asset/links and avoids mixed-content over HTTPS.
APP_URL=https://speedtest.<tailnet>.ts.net

# Cron schedule for automatic speedtests (default: every 6 hours)
SPEEDTEST_SCHEDULE=0 */6 * * *

# Tailscale auth for the sidecar — same OAuth client secret as the other sidecars
# (needs the Auth Keys scope + tag:container in the ACL). See ../HTTPS.md.
TS_AUTHKEY=
