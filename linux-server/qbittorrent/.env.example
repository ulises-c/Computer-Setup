# Copy this file to .env and set the values. See ../HTTPS.md for the full setup.

# Tailscale auth for the sidecar — same OAuth client secret as the other sidecars
# (needs the Auth Keys scope + tag:container in the ACL).
TS_AUTHKEY=

# Where to store completed/in-progress torrents.
# Default: ./downloads (same directory as docker-compose.yml)
# External drive example: QBITTORRENT_DOWNLOADS_PATH=/mnt/external/torrents
QBITTORRENT_DOWNLOADS_PATH=./downloads
